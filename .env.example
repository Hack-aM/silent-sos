# Silent SOS System — Environment Configuration Template
# Instructions: Copy this file to '.env' and replace with your own values.
# Do NOT commit your actual '.env' file to version control.

SECRET_KEY=replace-this-with-a-secure-random-key-in-production
DATABASE_URL=sqlite:///silent_sos.db
UPLOAD_FOLDER=uploads/audio
MAX_CONTENT_LENGTH=16777216

# ── Twilio SMS Alerts (optional) ──────────────────────────
# Get credentials free at https://twilio.com
# Leave blank to disable SMS (system still works without it)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
